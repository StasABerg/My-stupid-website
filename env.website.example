# Website services environment template.
# Copy to .env in /opt/website/dev/ or /opt/website/prod/ and fill in values.

# --- Dev / Prod toggle ---
IMAGE_TAG=ci-main-123            # explicit image tag (ci-* for dev, v* for prod)
APP_ENV=development              # "development" for dev, "production" for prod

# --- Ports (must differ between dev and prod) ---
FRONTEND_PORT=8091               # 8091 for dev, 8080 for prod
RADIO_PORT=4011                  # 4011 for dev, 4010 for prod

# --- Database ---
# dev:  postgres://appuser:PASSWORD@postgres:5432/appdb_dev
# prod: postgres://appuser:PASSWORD@postgres:5432/appdb
PG_URL=postgres://appuser:CHANGE_ME@postgres:5432/appdb_dev

# --- Secrets (shared between gateway, radio, fmd) ---
SESSION_SECRET=CHANGE_ME_MIN_32_CHARS
FMD_TOKEN=CHANGE_ME_MIN_32_CHARS
STATIONS_REFRESH_TOKEN=CHANGE_ME_MIN_32_CHARS

# --- CORS ---
# dev:  https://dev.gitgud.zip
# prod: https://gitgud.zip,https://dev.gitgud.zip
CORS_ALLOW_ORIGIN=https://dev.gitgud.zip

# --- Contact form (optional — leave empty to disable) ---
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USERNAME=
CONTACT_SMTP_PASSWORD=
CONTACT_FROM_ADDRESS=
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
